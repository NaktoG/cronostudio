# ===========================================
# CronoStudio Docker — Local Development
# ===========================================
# Copia este archivo a .env:  cp .env.example .env
# Los valores por defecto funcionan con docker-compose.yml sin cambios.

# --- PostgreSQL ---
POSTGRES_DB=cronostudio
POSTGRES_USER=crono
POSTGRES_PASSWORD=crono
DATABASE_URL=postgresql://crono:crono@localhost:5432/cronostudio

# --- CronoStudio Auth ---
# En producción genera con: openssl rand -base64 32
JWT_SECRET=local-dev-secret-change-in-production-min32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
LOG_LEVEL=info
ALLOW_PUBLIC_SIGNUP=false

# --- App URL ---
APP_BASE_URL=http://localhost:3000

# --- SMTP (Mailpit — ya incluido en docker-compose) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cronostudio.local

# --- Redis (ya incluido en docker-compose) ---
REDIS_URL=redis://localhost:6379/0
REDIS_SKIP_TLS_VERIFY=false

# --- Observabilidad ---
OBS_ENABLED=false
OBS_ENDPOINT=

# Requiere email verificado para iniciar sesión (true/false)
REQUIRE_EMAIL_VERIFIED=true

# --- n8n Legacy / Rollback only ---
# Solo se usa con el profile Docker `legacy-n8n`:
#   docker compose --profile legacy-n8n up
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change_me_openssl_rand_hex_32

# n8n -> Postgres (legacy only)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
WEBHOOK_URL=${N8N_PROTOCOL}://${N8N_HOST}:${N8N_PORT}/
CRONOSTUDIO_API_BASE_URL=http://host.docker.internal:3000/api
CRONOSTUDIO_EMAIL=demo@cronostudio.com
CRONOSTUDIO_PASSWORD=change_me
CRONOSTUDIO_WEBHOOK_SECRET=
