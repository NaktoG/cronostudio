# ===========================================
# CRONOSTUDIO — Web App (Local Development)
# ===========================================
# Copia a .env.local:  cp .env.example .env.local
# Los valores por defecto funcionan con docker-compose.yml sin cambios.
# NO commitear .env.local a version control.

# -------------------------------------------
# Database (coincide con docker-compose defaults)
# -------------------------------------------
POSTGRES_USER=crono
POSTGRES_PASSWORD=crono
POSTGRES_DB=cronostudio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://crono:crono@localhost:5432/cronostudio

# -------------------------------------------
# Authentication
# -------------------------------------------
# En producción genera con: openssl rand -base64 32
JWT_SECRET=local-dev-secret-change-in-production-min32chars
JWT_ISSUER=cronostudio-web
JWT_AUDIENCE=cronostudio-users

# -------------------------------------------
# API Configuration
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Rate Limiting (defaults razonables para dev)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_FILE_MAX_REQUESTS=10
RATE_LIMIT_FILE_WINDOW_MS=3600000

# -------------------------------------------
# Email — Mailpit (incluido en docker-compose)
# -------------------------------------------
# UI de Mailpit: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cronostudio.local
CONTACT_EMAIL=support@atonix.com

# -------------------------------------------
# Redis (incluido en docker-compose)
# -------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_SKIP_TLS_VERIFY=false

# -------------------------------------------
# Development & Testing
# -------------------------------------------
NODE_ENV=development

# Permite devolver links de verificación/reset cuando falla el email (solo dev)
ALLOW_DEBUG_LINKS=true

# Controla si se permiten registros públicos
ALLOW_PUBLIC_SIGNUP=false

# Requiere email verificado para iniciar sesión
REQUIRE_EMAIL_VERIFIED=true

# CSRF — desactivado en dev por defecto
CSRF_ENFORCE=false

# Session
SESSION_MAX_AGE=86400
SESSION_COOKIE_NAME=cronostudio_session

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------
# n8n Legacy (desactivado por defecto)
# -------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_ENABLED=false

# -------------------------------------------
# Google OAuth (YouTube + Analytics) — opcional
# -------------------------------------------
# Configura solo si vas a conectar canales de YouTube
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
# YOUTUBE_TOKEN_ENCRYPTION_KEY=
# OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=
# YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/yt-analytics.readonly

# -------------------------------------------
# OpenAI — opcional (para AI Studio)
# -------------------------------------------
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2
NEXT_PUBLIC_OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_OPENAI_MAX_OUTPUT_TOKENS=1200

# -------------------------------------------
# Observability — opcional
# -------------------------------------------
OBS_ENABLED=false
OBS_ENDPOINT=
OBS_ALERT_WEBHOOK=

# -------------------------------------------
# Crono Assistant (OpenClaw) — opcional
# -------------------------------------------
CRONO_ASSISTANT_ENABLED=false
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# -------------------------------------------
# Webhook secret (n8n -> CronoStudio)
# -------------------------------------------
CRONOSTUDIO_WEBHOOK_SECRET=
