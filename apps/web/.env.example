# ===========================================
# CRONOSTUDIO - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to version control

# -------------------------------------------
# Database Configuration
# -------------------------------------------
POSTGRES_USER=USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=DBNAME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# -------------------------------------------
# Supabase (if using Supabase instead of local PostgreSQL)
# -------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------------------------------
# Authentication
# -------------------------------------------
# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_32+
JWT_ISSUER=cronostudio-web
JWT_AUDIENCE=cronostudio-users

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32+

# OAuth Providers (opcional)
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# -------------------------------------------
# API Configuration
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
# Login rate limit
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
# File upload rate limit
RATE_LIMIT_FILE_MAX_REQUESTS=10
RATE_LIMIT_FILE_WINDOW_MS=3600000
# RATE_LIMIT_DISABLE=false
# RATE_LIMIT_ENFORCE=false
# RATE_LIMIT_TRUST_PROXY=false

# -------------------------------------------
# AI/LLM Integration (Agente 06)
# -------------------------------------------
# OpenAI
# OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Google Gemini
# GOOGLE_AI_API_KEY=your_google_ai_api_key

# -------------------------------------------
# n8n Legacy / Rollback only
# -------------------------------------------
# Mantener desactivado por defecto. Solo habilitar para rollback controlado.
N8N_BASE_URL=http://localhost:5678
N8N_ENABLED=false
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/
# N8N_API_KEY=your_n8n_api_key

# Google OAuth (YouTube + Analytics)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
YOUTUBE_TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/yt-analytics.readonly

# Legacy (fallback)
YOUTUBE_OAUTH_CLIENT_ID=CHANGE_ME
YOUTUBE_OAUTH_CLIENT_SECRET=CHANGE_ME
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/youtube/callback

# -------------------------------------------
# OpenAI
# -------------------------------------------
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2

# Public (UI display only)
NEXT_PUBLIC_OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_OPENAI_MAX_OUTPUT_TOKENS=1200

# -------------------------------------------
# Storage (Images, Videos, Thumbnails)
# -------------------------------------------
# AWS S3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=cronostudio-assets

# Cloudinary (alternative)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# -------------------------------------------
# Email Service (Notifications)
# -------------------------------------------
# SMTP (local recomendado: Mailpit en 1025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cronostudio.local
CONTACT_EMAIL=support@atonix.com

# SendGrid (legacy)
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@cronostudio.com

# Resend (alternative)
# RESEND_API_KEY=your_resend_api_key

# -------------------------------------------
# Analytics & Monitoring
# -------------------------------------------
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
# NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# -------------------------------------------
# Observability
# -------------------------------------------
OBS_ENABLED=false
OBS_ENDPOINT=
OBS_ALERT_WEBHOOK=

# -------------------------------------------
# Redis (rate limiting / sessions)
# -------------------------------------------
# Local recomendado: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_SKIP_TLS_VERIFY=false

# -------------------------------------------
# Development & Testing
# -------------------------------------------
NODE_ENV=development

# Enable debug logs
# DEBUG=true

# Test Database (for running tests)
# TEST_DATABASE_URL=postgresql://crono:crono@localhost:5432/cronostudio_test

# -------------------------------------------
# Security (Agente 14)
# -------------------------------------------
# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# CSP overrides (comma-separated)
# CSP_DEFAULT_SRC=
# CSP_BASE_URI=
# CSP_FRAME_ANCESTORS=
# CSP_OBJECT_SRC=
# CSP_CONNECT_SRC=https://api.openai.com,https://api.anthropic.com
# CSP_IMG_SRC=https://res.cloudinary.com,https://images.example.com
# CSP_SCRIPT_SRC=
# CSP_STYLE_SRC=
# CSP_FONT_SRC=https://fonts.gstatic.com
# CSP_REPORT_ONLY=false
# CSP_REPORT_URI=http://localhost:3000/api/csp-report
# CSP_STYLE_UNSAFE_INLINE=true

# Webhook shared secret (n8n -> CronoStudio)
# Usa un valor aleatorio y configúralo también en n8n como header:
# x-cronostudio-webhook-secret
CRONOSTUDIO_WEBHOOK_SECRET=

# Session Configuration
SESSION_MAX_AGE=86400
SESSION_COOKIE_NAME=cronostudio_session

# CSRF Protection
# CSRF_SECRET=your_csrf_secret
# Enforce CSRF checks for cookie-authenticated mutation requests
CSRF_ENFORCE=false

# Crono assistant gateway (OpenClaw)
CRONO_ASSISTANT_ENABLED=false
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# -------------------------------------------
# CI/CD (Agente 03)
# -------------------------------------------
# Vercel (if deploying to Vercel)
# VERCEL_TOKEN=your_vercel_token

# Docker Registry
# DOCKER_REGISTRY=your_docker_registry
# DOCKER_USERNAME=your_docker_username
# DOCKER_PASSWORD=your_docker_password

# -------------------------------------------
# Feature Flags
# -------------------------------------------
# FEATURE_IDEAS_MODULE=true
# FEATURE_SCRIPTS_MODULE=true
# FEATURE_THUMBNAILS_MODULE=true
# FEATURE_SEO_MODULE=true
# FEATURE_ANALYTICS_MODULE=true
# FEATURE_AUTOMATIONS_MODULE=true

# Controla si se permiten registros públicos (true/false)
ALLOW_PUBLIC_SIGNUP=false

# Permite devolver links de verificacion/reset cuando falla el email (solo local)
ALLOW_DEBUG_LINKS=true

# Requiere email verificado para iniciar sesión (true/false)
REQUIRE_EMAIL_VERIFIED=true
